# Robust .htaccess for Next.js Static Export on Apache/LiteSpeed (cPanel)

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Handle Trailing Slash (Since trailingSlash: true is set in next.config.ts)
  # This ensures files like /path/index.html are served when /path/ is requested
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)$ $1/index.html [L]

  # 3. Handle physical files if they exist (images, videos, fonts, etc.)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule .? - [L]

  # 4. Handle Next.js RSC Data (.txt files) and other generated assets
  # This ensures files like __next.contact.__PAGE__.txt are served correctly
  # even if requested with a query string like ?_rsc=...
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)\.txt$ $1.txt [L,QSA]

  # 5. Fallback for client-side routing (Single Page Application behavior)
  # If a directory exists but no file exists, serve index.html
  # This is crucial for Next.js static routing on Apache
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/?$ $1/index.html [L]

</IfModule>

# Correct MIME types for videos and modern formats
<IfModule mod_mime.c>
  AddType video/mp4 .mp4
  AddType video/webm .webm
  AddType image/webp .webp
  AddType image/avif .avif
</IfModule>

# Cache control for static assets to improve performance
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# Ensure index.html is the default directory index
DirectoryIndex index.html
